-push_front:
this is a function is used to add elements At the start of the list
exemple:

---------------------------------------------------------------
#include <iostream>
#include <list>

int main() {
    std::list<int> myList;

    // Adding elements to the front of the list
    myList.push_front(10);
    myList.push_front(20);
    myList.push_front(30);

    // Printing the list
    for (int num : myList) {
        std::cout << num << " ";
    }
    return 0;
}
---------------------------------------------------------------

-push_back:
this is the same thing as "push_front", but "push_back" adds elements to the back of the list
exemple:

---------------------------------------------------------------
#include <iostream>
#include <list>

int main() {
    std::list<int> myList;

    myList.push_back(10);
    myList.push_back(20);
    myList.push_back(30);

    for (int num : myList) {
        std::cout << num << " ";
    }

    return 0;
}
---------------------------------------------------------------

-pop_front:
this function is used to Removes the first element from the deque
exemple:

---------------------------------------------------------------
#include <iostream>
#include <deque>

int main() {
    std::deque<int> myDeque;

    // Adding elements
    myDeque.push_back(10);
    myDeque.push_back(20);
    myDeque.push_back(30);

    // Removing element from the front
    myDeque.pop_front(); // Removes 10

    // Printing the deque
    for (int num : myDeque) {
        std::cout << num << " ";
    }
    return 0;
}
---------------------------------------------------------------

-pop_back:
